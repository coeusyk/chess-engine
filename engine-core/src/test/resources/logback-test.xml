<configuration>
    <!-- Suppress most engine-core log output during unit tests.
         Only WARN and above are shown, routed to stderr to keep
         surefire test output clean. -->
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%level [%logger{25}] %msg%n</pattern>
        </encoder>
    </appender>

    <root level="WARN">
        <appender-ref ref="STDERR"/>
    </root>
</configuration>
