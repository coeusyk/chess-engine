#
# Seed #1 — Issue #125: KQ vs K — pre-fix engine drew by 3-fold repetition (score=0) when winning.
# DRAW_CONTEMPT=50 fix causes engine to penalise repetitions and find a winning move instead.
4k3/8/8/8/8/8/8/4KQ2 w - - c0 "draw_failure issue_125 KQvK engine-drew-by-repetition contempt-fix";
#
# Seed #2 — Issue #125: KR vs K — same root cause, same contempt fix.
4k3/8/8/8/8/8/8/4KR2 w - - c0 "draw_failure issue_125 KRvK engine-drew-by-repetition contempt-fix";
